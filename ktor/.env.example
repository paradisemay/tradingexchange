# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=broker
POSTGRES_USER=broker_app
POSTGRES_PASSWORD=change-me
POSTGRES_MAX_POOL_SIZE=30
POSTGRES_CONNECTION_TIMEOUT_MS=3000

# JWT
JWT_SECRET=change-me-use-strong-random-secret-min-32-chars
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30
JWT_ISSUER=ktor-broker
JWT_AUDIENCE=ktor-broker-clients

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_SERVICE_NAME=ktor-backend

# Server
PORT=8080
