# C-driver
DRIVER_DEVICE_PATH=/dev/quotes

# Redis (этап 2)
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_STREAM=stream:quotes:v1
REDIS_STREAM_MAXLEN=100000

# ClickHouse
CLICKHOUSE_ENABLED=false
CLICKHOUSE_ADDR=localhost:9000
CLICKHOUSE_DATABASE=trading
CLICKHOUSE_USER=trading_app
CLICKHOUSE_PASSWORD=change-me-local-clickhouse-password
CLICKHOUSE_TABLE=trading.quotes_raw
CLICKHOUSE_BATCH_SIZE=10000
CLICKHOUSE_FLUSH_INTERVAL_MS=200
CLICKHOUSE_INSERT_TIMEOUT_MS=5000
CLICKHOUSE_RETRY_INITIAL_MS=100
CLICKHOUSE_RETRY_MAX_MS=2000
CLICKHOUSE_DIAL_TIMEOUT_MS=5000

# Logging
LOG_LEVEL=info
