# Local Redis port exposed on the host.
REDIS_PORT=6379

# Optional. Leave empty for local development without authentication.
# Set a non-empty value in shared or deployed environments.
REDIS_PASSWORD=

# Redis memory cap. docker-compose.yml passes this to redis-server because
# redis.conf does not expand environment variables.
REDIS_MAXMEMORY=512mb

# Prometheus redis-exporter host port.
REDIS_EXPORTER_PORT=9121

# Quote stream contract for Go -> Redis -> Ktor integration.
REDIS_STREAM=stream:quotes:v1
REDIS_CONSUMER_GROUP=cg:ktor:quotes
REDIS_CONSUMER_NAME=ktor-instance-1
REDIS_STREAM_MAXLEN=100000
