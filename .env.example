# Core ports
POSTGRES_PORT=5432
REDIS_PORT=6379
KTOR_PORT=8080
API_MOCK_PORT=8081
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_TCP_PORT=9000
GRAFANA_PORT=3000
PROMETHEUS_PORT=9090
REDIS_EXPORTER_PORT=9121
POSTGRES_EXPORTER_PORT=9187
OTEL_COLLECTOR_GRPC_PORT=4317
OTEL_COLLECTOR_HTTP_PORT=4318
OTEL_COLLECTOR_PROMETHEUS_PORT=8889
OTEL_COLLECTOR_HEALTH_PORT=13133
LOKI_PORT=3100
TEMPO_HTTP_PORT=3200

# PostgreSQL
POSTGRES_DB=broker
POSTGRES_USER=broker_app
POSTGRES_PASSWORD=broker_app
POSTGRES_MAX_POOL_SIZE=30
POSTGRES_CONNECTION_TIMEOUT_MS=3000

# JWT / auth
JWT_SECRET=dev-secret-change-me-min-32-characters!!
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30
JWT_ISSUER=ktor-broker
JWT_AUDIENCE=ktor-broker-clients

# Redis
REDIS_PASSWORD=
REDIS_MAXMEMORY=512mb
REDIS_STREAM=stream:quotes:v1
REDIS_CONSUMER_GROUP=cg:ktor:quotes
REDIS_CONSUMER_NAME=ktor-instance-1
KTOR_REDIS_HOST=redis

# ClickHouse and collector
CLICKHOUSE_IMAGE=clickhouse/clickhouse-server:25.3-alpine
CLICKHOUSE_DATABASE=trading
CLICKHOUSE_USER=trading_app
CLICKHOUSE_PASSWORD=change-me
CLICKHOUSE_TABLE=quotes_raw
CLICKHOUSE_ENABLED=true
CLICKHOUSE_BATCH_SIZE=10000
CLICKHOUSE_FLUSH_INTERVAL_MS=200
CLICKHOUSE_INSERT_TIMEOUT_MS=5000
CLICKHOUSE_RETRY_INITIAL_MS=100
CLICKHOUSE_RETRY_MAX_MS=2000
CLICKHOUSE_DIAL_TIMEOUT_MS=5000
GO_LOG_LEVEL=info
MOCK_TICKERS=SBER,GAZP,YNDX,LKOH,ROSN
MOCK_INTERVAL_MS=100

# OpenTelemetry (disabled by default in Ktor)
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_SERVICE_NAME=ktor-backend
OTEL_TRACES_EXPORTER=none
OTEL_METRICS_EXPORTER=none
OTEL_LOGS_EXPORTER=none

# API mock profile
QUOTE_INTERVAL_MS=1000
MOCK_JWT=mock-access-token
MOCK_REFRESH_TOKEN=mock-refresh-token
MOCK_REFRESH_TOKEN_ROTATED=mock-refresh-token-rotated

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Android Vue APK job
ANDROID_VUE_API_BASE_URL=http://ktor:8080
