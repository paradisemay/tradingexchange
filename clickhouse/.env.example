# Local ClickHouse module settings.
# Copy to .env and replace placeholder values before running docker compose.

CLICKHOUSE_IMAGE=clickhouse/clickhouse-server:25.3-alpine
CLICKHOUSE_CONTAINER_NAME=tradingexchange-clickhouse

CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_TCP_PORT=9000

CLICKHOUSE_DATABASE=trading
CLICKHOUSE_USER=trading_app
CLICKHOUSE_PASSWORD=change-me-local-clickhouse-password

CLICKHOUSE_MAX_MEMORY_USAGE=10000000000
CLICKHOUSE_MAX_THREADS=8

